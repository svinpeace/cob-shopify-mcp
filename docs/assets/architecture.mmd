%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#6c63ff', 'lineColor': '#6c63ff', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'background': '#0a0a1a', 'mainBkg': '#1a1a2e', 'nodeBorder': '#6c63ff', 'clusterBkg': '#16213e', 'clusterBorder': '#6c63ff', 'titleColor': '#e0e0e0', 'edgeLabelBackground': '#1a1a2e', 'nodeTextColor': '#e0e0e0'}}}%%

flowchart TB
    %% ── Entry Points ──
    subgraph ENTRY["🚀 Entry Points"]
        direction LR
        CLI["🖥️ CLI\nconnect · serve · tools"]
        STDIO["📡 MCP Server\nstdio transport"]
        HTTP["🌐 HTTP Server\nStreamable HTTP"]
    end

    %% ── Core Engine ──
    subgraph CORE["⚙️ Core Engine (API-Agnostic)"]
        direction TB

        subgraph REGISTRY["📋 Registry & Discovery"]
            direction LR
            AD["🔍 Auto-Discover\n*.tool.ts · *.tool.yaml"]
            REG["📦 Tool Registry\nregister · list · filter"]
            CF["⚡ Config Filter\nenable · disable · tiers"]
        end

        subgraph ENGINES["🔧 MCP Engines"]
            direction LR
            TE["🛠️ Tool Engine\nschema gen · execute · map"]
            RE["📄 Resource Engine\nread-only data"]
            PE["💬 Prompt Engine\ntemplates · workflows"]
        end

        subgraph INFRA["🏗️ Infrastructure"]
            direction LR
            AUTH["🔐 Auth Manager\nstatic token · OAuth"]
            OBS["📊 Observability\nlogs · metrics · audit"]
            STORE["💾 Storage\nJSON · SQLite+encryption"]
        end

        DT["✨ defineTool() Helper"]
    end

    %% ── Shopify Shell ──
    subgraph SHOPIFY["🛍️ Shopify Shell"]
        direction TB

        subgraph CLIENT["🔗 Shopify GraphQL Client"]
            direction LR
            GQL["GraphQL Client\n@shopify/admin-api-client"]
            RL["⏱️ Rate Limiter"]
            CACHE["💨 Cache Layer"]
        end

        subgraph TOOLS["🧰 Tool Definitions (Co-located)"]
            direction LR
            PROD["📦 Products\n15 tools"]
            ORD["🧾 Orders\n12 tools"]
            CUST["👥 Customers\n9 tools"]
            INV["📊 Inventory\n7 tools"]
            ANAL["📈 Analytics\n6 tools"]
        end

        subgraph TIER2["🔒 Tier 2 (Disabled by Default)"]
            direction LR
            BILL["💳 Billing"]
            PAY["💰 Payments"]
            THEME["🎨 Themes"]
            SCONF["⚙️ Store Config"]
            MORE["... + more"]
        end

        subgraph MCPPRIM["🎯 MCP Primitives"]
            direction LR
            RES["📑 Resources\nshop info · locations"]
            PROMPT["💡 Prompts\nstore health · reports"]
        end
    end

    %% ── External ──
    SHOPIFY_API["🏪 Shopify Admin GraphQL API\nv2026-01"]

    %% ── Connections ──
    CLI --> CORE
    STDIO --> CORE
    HTTP --> CORE

    AD --> REG
    REG --> CF
    CF --> TE
    CF --> RE
    CF --> PE

    DT -.-> REG

    TE --> CLIENT
    RE --> CLIENT
    PE --> CLIENT

    AUTH --> CLIENT
    OBS -.-> TE
    STORE -.-> AUTH

    GQL --> RL
    RL --> CACHE

    TOOLS --> DT
    TIER2 --> DT
    MCPPRIM --> RE
    MCPPRIM --> PE

    CACHE --> SHOPIFY_API

    %% ── Styling ──
    classDef entryStyle fill:#2d1b69,stroke:#8b5cf6,stroke-width:2px,color:#e0e0e0
    classDef coreStyle fill:#1e3a5f,stroke:#3b82f6,stroke-width:2px,color:#e0e0e0
    classDef shopifyStyle fill:#1a4731,stroke:#10b981,stroke-width:2px,color:#e0e0e0
    classDef tier2Style fill:#4a1d1d,stroke:#ef4444,stroke-width:2px,color:#e0e0e0
    classDef apiStyle fill:#7c3aed,stroke:#a78bfa,stroke-width:3px,color:#ffffff,font-weight:bold
    classDef helperStyle fill:#7c2d12,stroke:#f97316,stroke-width:2px,color:#e0e0e0

    class CLI,STDIO,HTTP entryStyle
    class AD,REG,CF,TE,RE,PE,AUTH,OBS,STORE coreStyle
    class GQL,RL,CACHE,PROD,ORD,CUST,INV,ANAL,RES,PROMPT shopifyStyle
    class BILL,PAY,THEME,SCONF,MORE tier2Style
    class SHOPIFY_API apiStyle
    class DT helperStyle
