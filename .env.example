# =============================================================================
# cob-shopify-mcp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# See README.md → "Getting Shopify Credentials" for the full step-by-step.
# =============================================================================

# ---------------------------------------------------------------------------
# Shopify App Credentials (from the Developer Dashboard)
# ---------------------------------------------------------------------------
# Go to dev.shopify.com → Apps → your app → Settings tab
#
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ---------------------------------------------------------------------------
# Alternative: Static Access Token
# ---------------------------------------------------------------------------
# If you have a shpat_ token, set it here INSTEAD of Client ID/Secret above.
# When set, the server uses this token directly and ignores Client ID/Secret.
#
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Shopify API Version
# ---------------------------------------------------------------------------
SHOPIFY_API_VERSION=2025-01

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
COB_SHOPIFY_READ_ONLY=false
COB_SHOPIFY_LOG_LEVEL=info
COB_SHOPIFY_STORAGE_BACKEND=json

# Transport (only needed for Docker / HTTP mode)
# COB_SHOPIFY_TRANSPORT=http
# COB_SHOPIFY_PORT=3000
# COB_SHOPIFY_HOST=0.0.0.0
